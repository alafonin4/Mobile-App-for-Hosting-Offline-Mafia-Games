{
  "expo": {
    "name": "Mafia Mobile",
    "slug": "mafia-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "mafia-mobile",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/icon.png"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ],
      "package": "com.alafonin4.mafiaapp",
      "intentFilters": [],
      "blockedPermissions": []
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-build-properties",
          {
            "android": {
              "usesCleartextTraffic": true
            } 
          } 
      ],
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0A0A0D",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 240,
          "resizeMode": "contain"
        }
      ],
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow camera access to scan room QR codes."
        }
      ],
      "expo-image",
      "expo-web-browser",
      "expo-build-properties"
    ],
    "extra": {
      "apiUrl": "${EXPO_PUBLIC_API_URL}",
      "router": {},
      "eas": {
        "projectId": "8ae935b4-623f-47d8-bae8-ad72508e5f00"
      }
    },
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "owner": "alafonin4"
  }
}
